{
  "name": "@nexus-core/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "prisma generate --schema=../../packages/database/prisma/schema.prisma && nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.1",
    "@nexus-core/database": "*",
    "@nexus-core/shared": "*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-parse": "^5.6.0",
    "date-fns": "^4.1.0",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^7.0.6",
    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.3",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "ts-loader": "^9.5.4",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
