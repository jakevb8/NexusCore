# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Get these from https://console.neon.tech → Connection Details
DATABASE_URL="postgresql://USER:PASSWORD@HOST/nexus-core?sslmode=require&pgbouncer=true"
DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@HOST/nexus-core?sslmode=require"

# ─── Firebase Admin SDK (Server-side) ────────────────────────────────────────
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
PORT=3001
NODE_ENV=development
